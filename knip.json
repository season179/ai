{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreDependencies": ["@faker-js/faker"],
  "ignoreWorkspaces": [
    "examples/**",
    "testing/**",
    "packages/ai-code-mode/models-eval"
  ],
  "ignore": [
    "scripts/**",
    "packages/ai-code-mode-skills/test-cli/**",
    ".claude/worktrees/**",
    "packages/ai-openai/live-tests/**",
    "packages/ai-openai/src/**/*.test.ts",
    "packages/ai-openai/src/audio/audio-provider-options.ts",
    "packages/ai-openai/src/audio/transcribe-provider-options.ts",
    "packages/ai-openai/src/image/image-provider-options.ts",
    "packages/ai-devtools/src/production.ts",
    "codemods/**/__testfixtures__/**"
  ],
  "ignoreExportsUsedInFile": true,
  "workspaces": {
    "packages/react-ai": {
      "ignore": []
    },
    "packages/ai": {
      "ignoreDependencies": ["@opentelemetry/api"]
    },
    "packages/ai-anthropic": {
      "ignore": ["src/tools/**"]
    },
    "packages/ai-gemini": {
      "ignore": ["src/tools/**"]
    },
    "packages/ai-openai": {
      "ignore": ["src/tools/**"]
    },
    "packages/ai-client": {
      "ignoreDependencies": ["@standard-schema/spec"]
    },
    "packages/ai-react-ui": {
      "ignoreDependencies": ["react-dom"]
    },
    "packages/ai-vue-ui": {
      "ignore": ["src/use-chat-context.ts"]
    }
  }
}
